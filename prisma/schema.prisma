generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String?
  role         Role          @default(USER)
  reservations Reservation[]
  createdAt    DateTime      @default(now())
}

model Resource {
  id           String        @id @default(uuid())
  name         String
  description  String
  location     String
  reservations Reservation[]
  horarios     Horario[]
  createdAt    DateTime      @default(now())
}

model Reservation {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  resource   Resource @relation(fields: [resourceId], references: [id])
  resourceId String
  date       DateTime
  endTime    DateTime
  createdAt  DateTime @default(now())
}

model Horario {
  id         String   @id @default(uuid())
  resource   Resource @relation(fields: [resourceId], references: [id])
  resourceId String
  day        String
  startTime  DateTime
  endTime    DateTime
  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}
